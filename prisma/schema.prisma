generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Player {
  id    String @id @default(cuid())
  name  String @unique
  score Int    @default(0)
}

model GameRoom {
  id      String @id @default(cuid())
  name    String @unique
  coins   Json
  players Json
  mode    String @default("classic") // classic или timeattack
}